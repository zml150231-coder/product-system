<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>Product Development Record Sheet</title>
  <style>
    body {
      font-family: Arial, "Microsoft YaHei", sans-serif;
      background: white;
      margin: 0;
      padding: 20px;
    }

    h1 {
      margin-top: 0;
    }

    .btn-bar {
      margin-bottom: 20px;
    }

    .btn {
      display: inline-block;
      background: #2f6fed;
      color: white;
      text-decoration: none;
      padding: 10px 16px;
      border-radius: 4px;
      margin-right: 10px;
      font-size: 14px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
    }

    th, td {
      border: 1px solid #ccc;
      padding: 10px;
      text-align: left;
      font-size: 14px;
    }

    th {
      background: #f2f2f2;
    }
  </style>
</head>
<body>
  <h1>Product Development Record Sheet</h1>

  <div class="btn-bar">
    <a class="btn" href="/form">新增产品</a>
    <% if (user && user.isAdmin) { %>
      <a class="btn" href="/users">查看用户</a>
    <% } %>
    <a class="btn" href="/logout">退出登录</a>
  </div>

  <table>
    <tr>
      <th>ID</th>
      <th>表单名称</th>
      <th>产品名称</th>
      <th>用户</th>
      <th>时间</th>
    </tr>

    <% if (products && products.length > 0) { %>
      <% products.forEach(function(item) { %>
        <tr>
          <td><%= item.id %></td>
          <td><%= item.formName || "" %></td>
          <td><%= item.productName || "" %></td>
          <td><%= item.username || "" %></td>
          <td><%= item.createdAt || "" %></td>
        </tr>
      <% }) %>
    <% } %>
  </table>
</body>
</html>
