<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>新增产品</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, "Microsoft YaHei", sans-serif;
      background: white;
      color: #222;
    }

    .topbar {
      padding: 16px 20px;
      border-bottom: 1px solid #ccc;
      background: white;
    }

    .topbar h1 {
      margin: 0;
      font-size: 24px;
    }

    .btn-bar {
      margin-top: 12px;
    }

    .btn {
      display: inline-block;
      background: #2f6fed;
      color: white;
      text-decoration: none;
      padding: 10px 16px;
      border-radius: 4px;
      margin-right: 10px;
      font-size: 14px;
      border: none;
      cursor: pointer;
    }

    .page {
      width: 1360px;
      margin: 10px auto 30px auto;
      background: white;
      border: 1px solid #aaa;
    }

    .section {
      border-bottom: 1px solid #888;
      background: #d8d8d8;
    }

    table.layout {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      font-size: 14px;
    }

    table.layout td,
    table.layout th {
      border: 1px solid #8f8f8f;
      padding: 6px 8px;
      vertical-align: middle;
      background: #efefef;
    }

    .label {
      background: #e3e3e3 !important;
      text-align: right;
      white-space: nowrap;
    }

    .input,
    .textarea {
      width: 100%;
      box-sizing: border-box;
      border: 1px solid #999;
      background: #f8f8f8;
      padding: 6px 8px;
      font-size: 14px;
    }

    .input {
      height: 30px;
    }

    .textarea {
      height: 90px;
      resize: vertical;
    }

    .photo-box {
      height: 300px;
      border: 1px solid #bbb;
      background: #f6f6f6;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #aaa;
      font-size: 40px;
    }

    .photo-inner {
      text-align: center;
    }

    .photo-inner span {
      display: block;
      margin-top: 8px;
      font-size: 18px;
      color: #bbb;
    }

    .upload-row {
      margin-top: 10px;
      font-size: 13px;
      color: #444;
    }

    .white-gap {
      height: 70px;
      background: white;
      border-top: 1px solid #8f8f8f;
      border-bottom: 1px solid #8f8f8f;
    }

    .title-bar {
      background: #a8a8a8 !important;
      color: white;
      text-align: center;
      font-size: 20px;
      font-weight: bold;
    }

    .left-title {
      background: #8c8c8c !important;
      color: white;
      text-align: center;
      font-size: 24px;
      writing-mode: vertical-rl;
      text-orientation: mixed;
      letter-spacing: 2px;
      width: 70px;
    }

    .submit-wrap {
      padding: 14px;
      background: #d8d8d8;
    }

    .submit-btn {
      width: 100%;
      height: 42px;
      background: #2f6fed;
      border: none;
      color: white;
      font-size: 16px;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <div class="topbar">
    <h1>Product Development Record Sheet</h1>
    <div class="btn-bar">
      <a class="btn" href="/list">返回列表</a>
      <a class="btn" href="/logout">退出登录</a>
    </div>
  </div>

  <div class="page">
    <form method="POST" action="/save">
      <div class="section">
        <table class="layout">
          <colgroup>
            <col style="width:390px;">
            <col style="width:260px;">
            <col style="width:250px;">
            <col style="width:230px;">
            <col style="width:230px;">
          </colgroup>

          <tr>
            <td rowspan="8" style="vertical-align:top;">
              <div class="photo-box">
                <div class="photo-inner">
                  ⓘ
                  <span>暂无照片</span>
                </div>
              </div>
              <div class="upload-row">上传图片　删除图片</div>
            </td>

            <td class="label">表单名称*</td>
            <td><input class="input" name="formName"></td>
            <td class="label">产品名称*</td>
            <td><input class="input" name="productName"></td>
          </tr>

          <tr>
            <td class="label">产品编号</td>
            <td><input class="input" name="productCode"></td>
            <td class="label">汇率</td>
            <td><input class="input" name="exchangeRate"></td>
          </tr>

          <tr>
            <td class="label">采购成本(RMB)*</td>
            <td><input class="input" name="purchaseCost"></td>
            <td class="label">佣金(%)</td>
            <td><input class="input" name="commissionRate"></td>
          </tr>

          <tr>
            <td class="label">分销价*</td>
            <td><input class="input" name="fenxiaoPrice"></td>
            <td class="label">广告费(%)</td>
            <td><input class="input" name="adRate"></td>
          </tr>

          <tr>
            <td class="label">分销减采购成本利润*</td>
            <td><input class="input" name="profitCostDiff"></td>
            <td class="label">利润率1(%)*</td>
            <td><input class="input" name="profitRate1"></td>
          </tr>

          <tr>
            <td class="label">销售价(USD)*</td>
            <td><input class="input" name="sellingPriceUsd"></td>
            <td class="label">销售价(RMB)*</td>
            <td><input class="input" name="sellingPriceRmb"></td>
          </tr>

          <tr>
            <td class="label">销售价-分销价利润*</td>
            <td><input class="input" name="profitSellDiff"></td>
            <td class="label">利润率2(%)*</td>
            <td><input class="input" name="profitRate2"></td>
          </tr>

          <tr>
            <td class="label">备注</td>
            <td colspan="3"><textarea class="textarea" name="remark"></textarea></td>
          </tr>
        </table>
      </div>

      <div class="white-gap"></div>

      <div class="section">
        <table class="layout">
          <colgroup>
            <col style="width:90px;">
            <col style="width:240px;">
            <col style="width:60px;">
            <col style="width:240px;">
            <col style="width:240px;">
            <col style="width:240px;">
            <col style="width:240px;">
          </colgroup>

          <tr>
            <td class="label">包装方式*</td>
            <td><input class="input" name="packageType"></td>
            <td colspan="2" class="title-bar">包装尺寸</td>
            <th>长/CM</th>
            <th>宽/CM</th>
            <th>高/CM</th>
          </tr>

          <tr>
            <td class="label">体积重1(/6000)*</td>
            <td><input class="input" name="volumeWeight6000"></td>
            <td>KG</td>
            <td></td>
            <td><input class="input" name="lengthCm"></td>
            <td><input class="input" name="widthCm"></td>
            <td><input class="input" name="heightCm"></td>
          </tr>

          <tr>
            <td class="label">体积重2(/5000)*</td>
            <td><input class="input" name="volumeWeight5000"></td>
            <td>KG</td>
            <td colspan="4"></td>
          </tr>

          <tr>
            <td class="label">实重*</td>
            <td><input class="input" name="actualWeight"></td>
            <td>KG</td>
            <td colspan="4"></td>
          </tr>
        </table>
      </div>

      <div class="white-gap"></div>

      <div class="section">
        <table class="layout">
          <colgroup>
            <col style="width:90px;">
            <col style="width:240px;">
            <col style="width:100px;">
            <col style="width:240px;">
            <col style="width:170px;">
            <col style="width:240px;">
            <col style="width:170px;">
            <col style="width:170px;">
          </colgroup>

          <tr>
            <td rowspan="4" class="left-title">运输方式</td>
            <th></th><th></th><th></th><th></th><th></th><th></th><th></th>
          </tr>

          <tr>
            <td class="label">快递:</td>
            <td><input class="input" name="expressFee"></td>
            <td>(RMB) 利润</td>
            <td><input class="input" name="expressProfit"></td>
            <td>(RMB)</td>
            <td class="label">利润率(%)*</td>
            <td><input class="input" name="expressProfitRate"></td>
          </tr>

          <tr>
            <td class="label">空运:</td>
            <td><input class="input" name="airFee"></td>
            <td>(RMB) 利润</td>
            <td><input class="input" name="airProfit"></td>
            <td>(RMB)</td>
            <td class="label">利润率(%)*</td>
            <td><input class="input" name="airProfitRate"></td>
          </tr>

          <tr>
            <td class="label">海运:</td>
            <td><input class="input" name="seaFee"></td>
            <td>(RMB) 利润</td>
            <td><input class="input" name="seaProfit"></td>
            <td>(RMB)</td>
            <td class="label">利润率(%)*</td>
            <td><input class="input" name="seaProfitRate"></td>
          </tr>
        </table>
      </div>

      <div class="white-gap"></div>

      <div class="submit-wrap">
        <button class="submit-btn" type="submit">提交</button>
      </div>
    </form>
  </div>
</body>
</html>
